{
  "version": 2,
  "installCommand": "npm --prefix Backend install && npm --prefix Frontend install",
  "builds": [
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "Backend/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/user/(.*)", "dest": "Backend/index.js" },
    { "src": "/trip/(.*)", "dest": "Backend/index.js" },
    { "src": "/transaction/(.*)", "dest": "Backend/index.js" },
    { "src": "/health", "dest": "Backend/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
